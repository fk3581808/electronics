                    <span class="text-slate-400"># Generate the 2D array using nested loops</span><br/>
                    <span class="text-pink-400 font-bold">for</span> <span class="text-sky-300">i</span> <span class="text-pink-400 font-bold">in</span> <span class="text-emerald-300">range</span>(<span class="text-sky-300">m</span>):<br/>
