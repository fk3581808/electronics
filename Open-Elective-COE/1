                    &nbsp;&nbsp;&nbsp;&nbsp;<span class="text-pink-400 font-bold">for</span> <span class="text-sky-300">j</span> <span class="text-pink-400 font-bold">in</span> <span class="text-emerald-300">range</span>(<span class="text-sky-300">n</span>):<br/>
                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-slate-500"># Calculate value (example: i * j) and add to row</span><br/>
